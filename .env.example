# Flight Schedule Pro Credentials
# IMPORTANT: Copy this file to .env and add your actual credentials
FSP_EMAIL=your-email@example.com
FSP_PASSWORD=your-password-here

# Scheduling Configuration
DAYS_AHEAD=60
# Use callsigns (tail numbers), not aircraft types
# Example: N65411|N734UZ matches those specific aircraft
AIRCRAFT_REGEX=N65411|N734UZ

# Timing Preferences
WEEKDAY_MIN_HOUR=15
MAX_HOUR=19
