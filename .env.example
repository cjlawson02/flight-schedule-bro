# Flight Schedule Pro Credentials
# IMPORTANT: Copy this file to .env and add your actual credentials
FSP_EMAIL=your-email@example.com
FSP_PASSWORD=your-password-here

# Scheduling Configuration (CLI only — the worker uses wrangler.toml instead)
DAYS_AHEAD=60
# Use callsigns (tail numbers), not aircraft types
# Example: N65411|N737BC matches those specific aircraft
AIRCRAFT_REGEX=N65411|N737BC
# Instructor name pattern for default selection in the CLI
INSTRUCTOR_REGEX=Doug Libal

# Timing Preferences
TIMEZONE=America/Los_Angeles
WEEKDAY_MIN_HOUR=15
WEEKEND_MIN_HOUR=8
MAX_HOUR=19
